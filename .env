# Base URL of the backend host, no trailing slash and no path (e.g. http://localhost:8000)
VITE_API_URL=http://localhost:8000

# API path prefix appended to VITE_API_URL for every request. Update this once the
# backend team confirms/changes it after deployment — every service reads it from
# here via src/services/apiClient.js, nothing else needs to change.
VITE_API_PREFIX=/api/v1
